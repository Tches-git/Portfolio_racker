# LLM Provider: zhipu / openai
LLM_PROVIDER=zhipu

# --- Zhipu ---
ZHIPUAI_API_KEY=your_zhipu_api_key_here
LLM_MODEL=glm-5.1
LLM_MODEL_PLUS=glm-5.1
EMBED_MODEL=embedding-3

# --- OpenAI-compatible (optional) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Web access control (optional) ---
WEB_UI_PASSWORD=

# --- Product frontend/API bridge (optional) ---
# Server-side URL used by Next.js rewrites and server-rendered routes.
API_BASE_URL=http://127.0.0.1:8000
# Leave empty for same-origin browser calls through Next.js /api/v1 rewrites.
NEXT_PUBLIC_API_BASE_URL=

# --- Multi-user/PostgreSQL deployment ---
DATABASE_URL=postgresql+psycopg://portfolio:change-me@postgres:5432/portfolio_tracker
REDIS_URL=redis://redis:6379/0
AUTH_SECRET=replace_with_a_long_random_secret
AUTH_COOKIE_NAME=portfolio_session
AUTH_TOKEN_TTL_SECONDS=86400
AUTH_REQUIRED=true
ENABLE_SIGNUP=true
SIGNUP_RATE_LIMIT_PER_HOUR=10
LOGIN_RATE_LIMIT_PER_HOUR=30

# --- Docker Compose/Caddy ---
POSTGRES_DB=portfolio_tracker
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=replace_with_a_strong_database_password
APP_DOMAIN=:80
CADDY_EMAIL=

# --- Runtime knobs (optional) ---
MC_SIMULATIONS=1000
MAX_AGENT_STEPS=15
MAX_REPORT_RAG_CONTEXTS=5
MAX_REPORT_RAG_CHARS=4000
MAX_REPORT_HISTORY_CHARS=1200
MAX_REPORT_CONCLUSION_CHARS=2500
CACHE_TTL_DEFAULT=3600
CACHE_TTL_PROFILE=1800
CACHE_TTL_FINANCIALS=86400
